generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  is_active Boolean @default(true)
  sys_admin Boolean @default(false)
  name      String  @db.VarChar(255)
  email     String  @unique
  nickname  String? @db.VarChar(255)
  password  String?

  birth_date DateTime? @db.Date

  rg    String?
  cpf   String?
  phone String?

  avatar Bytes?

  address Json?

  account_stage String?
  language      String
  theme         String

  observation String? @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamp
  updated_at DateTime @updatedAt @db.Timestamp

  group_id String?
  Group    Group?  @relation(fields: [group_id], references: [id])

  passwordChanges   PasswordChange[]
  permissionUsers   PermissionUser[]
  emergencyContacts EmergencyContact[]
  publications      Publication[]

  @@map("users")
}

model Group {
  id        String  @id @default(uuid())
  is_active Boolean @default(true)
  name      String  @db.VarChar(255)
  email     String?
  shortname String? @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamp
  updated_at DateTime @updatedAt @db.Timestamp

  users        User[]
  categories   Category[]
  publications Publication[]

  @@map("groups")
}

model PasswordChange {
  id      String @id @default(uuid())
  code    String
  token   String
  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  expires_at DateTime

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("password_changes")
}

model PermissionUser {
  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  profile String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@id([user_id, profile])
  @@map("permission_users")
}

model EmergencyContact {
  id           String  @id @default(uuid())
  name         String
  phone        String
  relationship String?

  avatar Bytes?

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  @@map("emergency_contacts")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  group_id    String?
  Group       Group?  @relation(fields: [group_id], references: [id])

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("categories")
}

model Publication {
  id          String  @id @default(uuid())
  title       String  @db.VarChar(255)
  description String? @db.Text
  link        Json?

  group_id String?
  Group    Group?  @relation(fields: [group_id], references: [id])

  created_by String?
  createdBy  User?   @relation(fields: [created_by], references: [id])

  files      Json?
  categories Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("publications")
}
